# Copy to .env and fill in your values. NEVER commit .env to git.

# Hugging Face Hub token (private datasets + model push)
HF_TOKEN=hf_...

# Gemini 2.5 Flash — Google AI Studio free tier (1500 req/day)
GEMINI_API_KEY=AIza...

# Weights & Biases
WANDB_API_KEY=...

# Neo4j Community (Docker)
NEO4J_PASSWORD=changeme

# Your HF username — used in config YAML and scripts
HF_USERNAME=your_hf_username
